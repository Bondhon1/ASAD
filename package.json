{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next dev --webpack",
    "dev:turbo": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next dev --turbopack",
    "generate": "prisma generate && prisma generate --schema=prisma/schema.audit.prisma && node -e \"const fs=require('fs');const path=require('path');const dirs=['node_modules/.prisma/client','src/generated/prisma-audit'];for(const dir of dirs){if(!fs.existsSync(dir)) continue;for(const entry of fs.readdirSync(dir)){if(!entry.includes('.tmp')) continue;const file=path.join(dir,entry);if(fs.statSync(file).isFile()) fs.unlinkSync(file);}}\"",
    "generate:audit": "prisma generate --schema=prisma/schema.audit.prisma && node -e \"const fs=require('fs');const path=require('path');const dirs=['node_modules/.prisma/client','src/generated/prisma-audit'];for(const dir of dirs){if(!fs.existsSync(dir)) continue;for(const entry of fs.readdirSync(dir)){if(!entry.includes('.tmp')) continue;const file=path.join(dir,entry);if(fs.statSync(file).isFile()) fs.unlinkSync(file);}}\"",
    "db:push:audit": "prisma db push --schema=prisma/schema.audit.prisma",
    "build": "npm run generate && cross-env NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:vercel": "npm run generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "npm run generate",
    "seed": "tsx prisma/seed.ts",
    "cleanup:post-seen": "tsx scripts/cleanup-post-seen.ts",
    "cap:sync": "npx cap sync android",
    "cap:copy": "npx cap copy android",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "android:debug": "cd android && gradlew.bat assembleDebug",
    "android:release": "cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-social-login": "^8.3.9",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.4.2",
    "@neondatabase/serverless": "^1.0.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-neon": "^6.19.0",
    "@prisma/client": "^6.19.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.1",
    "ably": "^2.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "framer-motion": "^12.23.25",
    "googleapis": "^168.0.0",
    "ical-generator": "^10.0.0",
    "lucide-react": "^0.559.0",
    "next": "^16.1.0",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.11",
    "prisma": "^6.19.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.68.0",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.9.19",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.4"
  }
}
